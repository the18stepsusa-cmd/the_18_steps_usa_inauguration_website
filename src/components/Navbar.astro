---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { name: 'Home', href: `${base}/` },
  { name: 'Chaayamukhi', href: `${base}/chaayamukhi` },
  { name: 'Donations', href: `${base}/donations` },
  { name: 'Gallery', href: `${base}/gallery` },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={`${base}/`} class="flex items-center gap-3 group">
        <img
          src={`${base}/images/aesthetic/the_18_steps_logo.jpg`}
          alt="The 18 Steps"
          class="w-12 h-12 rounded-full border-2 border-saffron/50 group-hover:border-saffron transition-colors"
        />
        <div class="hidden sm:block">
          <span class="font-display text-lg text-saffron font-semibold tracking-wider">THE 18 STEPS</span>
          <span class="block text-xs text-cream/60 tracking-widest">USA</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-cream/80 hover:text-saffron transition-colors duration-300 text-sm tracking-wider uppercase font-medium"
          >
            {link.name}
          </a>
        ))}
        <a href={`${base}/#rsvp`} class="btn-primary text-sm">RSVP Now</a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        class="md:hidden text-cream p-2"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" id="menu-icon" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden hidden bg-cosmic/95 backdrop-blur-lg border-t border-saffron/20" id="mobile-menu">
    <div class="px-4 py-6 space-y-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block text-cream/80 hover:text-saffron transition-colors text-sm tracking-wider uppercase py-2"
        >
          {link.name}
        </a>
      ))}
      <a href={`${base}/#rsvp`} class="btn-primary text-sm block text-center mt-4">RSVP Now</a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-cosmic/95', 'backdrop-blur-lg', 'shadow-lg', 'shadow-saffron/5');
    } else {
      navbar?.classList.remove('bg-cosmic/95', 'backdrop-blur-lg', 'shadow-lg', 'shadow-saffron/5');
    }
  });

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
