---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Our Sponsors | The 18 Steps USA Inauguration">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-cosmic-light/30 via-cosmic to-cosmic"></div>
    <div class="absolute inset-0 bg-pattern-mandala opacity-30"></div>

    <!-- Floating gold accents -->
    <div class="absolute top-20 left-10 w-32 h-32 bg-saffron/5 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-10 w-40 h-40 bg-gold-light/5 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
    <div class="absolute top-40 right-20 w-24 h-24 bg-amber/5 rounded-full blur-2xl animate-float" style="animation-delay: 4s;"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-24">
      <p class="text-saffron/70 text-sm tracking-[0.3em] uppercase mb-4 animate-slide-up font-medium">June 6, 2026 &middot; Placentia, California</p>
      <h1 class="text-5xl md:text-7xl font-display font-bold mb-6 animate-slide-up text-gradient-gold leading-tight">
        Our Sponsors
      </h1>
      <p class="font-serif text-xl md:text-2xl text-cream/70 italic mb-2 animate-slide-up">
        Partners in preserving Dharma, Heritage and Humanity
      </p>
      <div class="gold-divider"></div>
      <p class="text-cream/50 text-base mt-6 max-w-2xl mx-auto animate-slide-up leading-relaxed">
        The 18 Steps USA inauguration is made possible by the generous support of our sponsors. Their commitment to cultural preservation and community empowerment fuels this historic celebration.
      </p>
    </div>
  </section>

  <!-- ===== TITLE SPONSOR ===== -->
  <section class="py-32 bg-cosmic relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern-mandala opacity-15"></div>
    <!-- Decorative glows -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-saffron/3 rounded-full blur-3xl"></div>
    <div class="absolute top-10 left-10 w-48 h-48 bg-saffron/5 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-10 right-10 w-48 h-48 bg-gold-light/5 rounded-full blur-3xl animate-float" style="animation-delay: 3s;"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-20">
        <p class="text-saffron/60 text-xs tracking-[0.5em] uppercase mb-4">Presenting</p>
        <h2 class="section-title text-5xl md:text-6xl">Title Sponsor</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="title-sponsor-card group">
          <div class="absolute inset-0 bg-gradient-to-br from-saffron/5 via-transparent to-gold-light/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="absolute -inset-px rounded-2xl bg-gradient-to-r from-saffron/20 via-gold-light/10 to-saffron/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-sm"></div>
          <div class="relative z-10">
            <div class="bg-cosmic-light/20 rounded-2xl p-10 mb-8 flex items-center justify-center h-64 border-2 border-dashed border-saffron/15 group-hover:border-saffron/40 transition-all duration-500">
              <div class="text-center">
                <svg class="w-20 h-20 text-saffron/20 mx-auto mb-5 group-hover:text-saffron/40 transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <p class="text-saffron/30 text-lg tracking-[0.2em] uppercase group-hover:text-saffron/60 transition-colors duration-500">Your Logo Here</p>
              </div>
            </div>
            <div class="text-center">
              <h3 class="font-display text-3xl md:text-4xl text-cream/25 font-bold mb-3 group-hover:text-cream/50 transition-colors duration-500">Title Sponsor</h3>
              <p class="text-cream/15 text-base tracking-[0.15em] uppercase group-hover:text-cream/30 transition-colors duration-500">The most prestigious placement &middot; Exclusive recognition</p>
            </div>
          </div>
          <div class="title-sponsor-badge">Title Sponsor</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GOLD SPONSORS ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20 relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-3xl md:text-4xl">Gold Sponsors</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Joy Alukkas -->
        <div class="sponsor-card-gold group">
          <div class="bg-white rounded-xl p-5 mb-4 flex items-center justify-center h-32 group-hover:shadow-[0_0_30px_rgba(212,160,23,0.15)] transition-all duration-500">
            <img src="https://www.joyalukkas.in/media/wysiwyg/Joyalukkas_Logo.jpeg" alt="Joyalukkas Jewellery" class="max-h-24 max-w-full object-contain" />
          </div>
          <h3 class="font-display text-lg text-saffron font-bold mb-1 group-hover:text-gold-light transition-colors">Joyalukkas</h3>
          <p class="text-cream/40 text-xs tracking-wider uppercase mb-2">World's Favourite Jeweller</p>
          <p class="text-cream/50 text-xs leading-relaxed">One of India's largest jewellery brands with a global presence including Los Angeles.</p>
          <a href="https://www.joyalukkas.com/us/" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-saffron/60 hover:text-saffron text-xs mt-3 transition-colors">
            Visit Website
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>

        <!-- Speridian Technologies -->
        <div class="sponsor-card-gold group">
          <div class="bg-white rounded-xl p-5 mb-4 flex items-center justify-center h-32 group-hover:shadow-[0_0_30px_rgba(212,160,23,0.15)] transition-all duration-500">
            <img src="https://www.speridian.com/wp-content/uploads/2023/05/speridian_logo.svg" alt="Speridian Technologies" class="max-h-20 max-w-full object-contain" />
          </div>
          <h3 class="font-display text-lg text-saffron font-bold mb-1 group-hover:text-gold-light transition-colors">Speridian Technologies</h3>
          <p class="text-cream/40 text-xs tracking-wider uppercase mb-2">Technology-Fueled Innovation</p>
          <p class="text-cream/50 text-xs leading-relaxed">A leading IT solutions company driving digital transformation for businesses worldwide.</p>
          <a href="https://www.speridian.com/" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-saffron/60 hover:text-saffron text-xs mt-3 transition-colors">
            Visit Website
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>

        <!-- Placeholder -->
        <div class="sponsor-card-placeholder group">
          <div class="bg-cosmic-light/30 rounded-xl p-6 mb-4 flex items-center justify-center h-32 border-2 border-dashed border-saffron/15 group-hover:border-saffron/40 transition-all duration-500">
            <div class="text-center">
              <svg class="w-10 h-10 text-saffron/20 mx-auto mb-2 group-hover:text-saffron/40 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              <p class="text-saffron/30 text-xs tracking-wider uppercase group-hover:text-saffron/60 transition-colors">Your Logo Here</p>
            </div>
          </div>
          <p class="text-cream/30 text-sm text-center font-display tracking-wider">Available</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SILVER SPONSORS ===== -->
  <section class="py-24 bg-cosmic relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-3xl md:text-4xl" style="color: #c0c0c0;">Silver Sponsors</h2>
        <div class="w-24 h-0.5 mx-auto mt-6" style="background: linear-gradient(to right, transparent, #c0c0c0, transparent);"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[1, 2, 3, 4].map((_) => (
          <div class="sponsor-card-placeholder group">
            <div class="bg-cosmic-light/20 rounded-lg p-4 flex items-center justify-center h-24 border border-dashed border-cream/10 group-hover:border-cream/30 transition-all duration-500">
              <div class="text-center">
                <svg class="w-8 h-8 text-cream/15 mx-auto mb-1 group-hover:text-cream/30 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <p class="text-cream/20 text-[10px] tracking-wider uppercase group-hover:text-cream/40 transition-colors">Available</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== COMMUNITY PARTNERS ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20 relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-3xl md:text-4xl" style="color: #cd7f32;">Community Partners</h2>
        <div class="w-24 h-0.5 mx-auto mt-6" style="background: linear-gradient(to right, transparent, #cd7f32, transparent);"></div>
      </div>

      <div class="grid grid-cols-3 md:grid-cols-6 gap-4">
        {[1, 2, 3, 4, 5, 6].map((_) => (
          <div class="sponsor-card-placeholder group">
            <div class="bg-cosmic-light/10 rounded-lg p-3 flex items-center justify-center h-20 border border-dashed border-cream/5 group-hover:border-cream/20 transition-all duration-500">
              <svg class="w-6 h-6 text-cream/10 group-hover:text-cream/25 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PATRONS ===== -->
  <section class="py-28 bg-cosmic relative">
    <div class="absolute inset-0 bg-pattern-mandala opacity-10"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="section-title text-4xl md:text-5xl text-cream/80">Our Patrons</h2>
        <div class="w-24 h-0.5 mx-auto mt-6" style="background: linear-gradient(to right, transparent, var(--color-cream), transparent); opacity: 0.3;"></div>
        <p class="text-cream/50 text-base mt-4 font-serif italic">Individuals who believe in our mission and generously support our cause</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5">
        <div class="patron-card group">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-saffron/20 to-amber/10 flex items-center justify-center mx-auto mb-3 group-hover:from-saffron/40 group-hover:to-amber/30 transition-all duration-300">
            <span class="font-display text-saffron text-xl font-bold">R</span>
          </div>
          <p class="text-cream font-serif text-lg text-center group-hover:text-saffron transition-colors">Ram Das</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY SPONSOR CTA ===== -->
  <section class="py-28 bg-cosmic relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern-mandala opacity-20"></div>

    <!-- Decorative glows -->
    <div class="absolute top-0 left-1/4 w-72 h-72 bg-saffron/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-royal/10 rounded-full blur-3xl"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="section-title text-4xl md:text-5xl">Become a Sponsor</h2>
        <div class="gold-divider"></div>
        <p class="font-serif text-xl text-cream/60 italic mt-4">Join us in making history</p>
      </div>

      <!-- Impact Numbers -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        <div class="text-center">
          <p class="font-display text-4xl md:text-5xl font-bold text-gradient-gold">500+</p>
          <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">Expected Attendees</p>
        </div>
        <div class="text-center">
          <p class="font-display text-4xl md:text-5xl font-bold text-gradient-gold">50+</p>
          <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">Community Leaders</p>
        </div>
        <div class="text-center">
          <p class="font-display text-4xl md:text-5xl font-bold text-gradient-gold">10K+</p>
          <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">Online Reach</p>
        </div>
        <div class="text-center">
          <p class="font-display text-4xl md:text-5xl font-bold text-gradient-gold">1</p>
          <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">Historic Event</p>
        </div>
      </div>

      <!-- Benefits -->
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="card-dark group hover:border-saffron/40 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-saffron/10 flex items-center justify-center flex-shrink-0 group-hover:bg-saffron/20 transition-colors">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-cream font-semibold text-lg mb-1">Premium Brand Visibility</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Logo placement on event materials, website, social media, and live event projections seen by hundreds of attendees</p>
            </div>
          </div>
        </div>

        <div class="card-dark group hover:border-saffron/40 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-saffron/10 flex items-center justify-center flex-shrink-0 group-hover:bg-saffron/20 transition-colors">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-cream font-semibold text-lg mb-1">Community Connection</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Direct engagement with a vibrant, culturally rich community of professionals, families, and thought leaders</p>
            </div>
          </div>
        </div>

        <div class="card-dark group hover:border-saffron/40 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-saffron/10 flex items-center justify-center flex-shrink-0 group-hover:bg-saffron/20 transition-colors">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-cream font-semibold text-lg mb-1">Cultural Impact</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Associate your brand with the preservation of ancient heritage and traditions, making a meaningful social impact</p>
            </div>
          </div>
        </div>

        <div class="card-dark group hover:border-saffron/40 transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-saffron/10 flex items-center justify-center flex-shrink-0 group-hover:bg-saffron/20 transition-colors">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <h3 class="text-cream font-semibold text-lg mb-1">VIP Recognition</h3>
              <p class="text-cream/50 text-sm leading-relaxed">On-stage acknowledgement, VIP seating, meet the chief guest and dignitaries, and exclusive networking opportunities</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sponsorship Tiers Summary -->
      <div class="card-dark p-8 md:p-10 mb-12">
        <h3 class="font-display text-2xl text-center text-saffron mb-8 tracking-wider">Sponsorship Tiers</h3>
        <div class="space-y-6">
          <div class="flex items-center justify-between border-b border-saffron/10 pb-4">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full bg-gradient-to-r from-saffron to-gold-light shadow-[0_0_10px_rgba(212,160,23,0.5)]"></div>
              <span class="font-display text-lg text-saffron tracking-wider">Title Sponsor</span>
            </div>
            <span class="text-cream/50 text-sm">Premium placement &middot; Stage recognition &middot; VIP access</span>
          </div>
          <div class="flex items-center justify-between border-b border-saffron/10 pb-4">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full bg-gradient-to-r from-saffron/80 to-amber shadow-[0_0_8px_rgba(212,160,23,0.3)]"></div>
              <span class="font-display text-lg text-saffron/80 tracking-wider">Gold Sponsor</span>
            </div>
            <span class="text-cream/50 text-sm">Website &middot; Social media &middot; Event banner</span>
          </div>
          <div class="flex items-center justify-between border-b border-cream/5 pb-4">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full" style="background: linear-gradient(to right, #c0c0c0, #e8e8e8);"></div>
              <span class="font-display text-lg tracking-wider" style="color: #c0c0c0;">Silver Sponsor</span>
            </div>
            <span class="text-cream/50 text-sm">Website listing &middot; Social media mention</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full" style="background: linear-gradient(to right, #cd7f32, #e8a050);"></div>
              <span class="font-display text-lg tracking-wider" style="color: #cd7f32;">Community Partner</span>
            </div>
            <span class="text-cream/50 text-sm">Website logo &middot; Acknowledgement</span>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <p class="text-cream/60 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
          Ready to be part of something extraordinary? Reach out to discuss sponsorship opportunities tailored to your goals.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="mailto:info@the18stepsusa.org?subject=Sponsorship%20Inquiry%20-%20The%2018%20Steps%20USA%20Inauguration" class="btn-primary text-lg px-10 py-4">
            Contact Us to Sponsor
          </a>
          <a href="tel:+12672408324" class="btn-outline text-lg px-10 py-4">
            Call: +1 267 240 8324
          </a>
        </div>
        <p class="text-cream/30 text-xs mt-6">Jithesh Viswanadh (President) &middot; info@the18stepsusa.org</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .title-sponsor-card {
    position: relative;
    background: rgba(26, 26, 78, 0.5);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(212, 160, 23, 0.2);
    border-radius: 1rem;
    padding: 3rem;
    transition: all 0.6s;
    overflow: hidden;
  }
  .title-sponsor-card:hover {
    border-color: rgba(212, 160, 23, 0.5);
    box-shadow: 0 0 60px rgba(212, 160, 23, 0.1), 0 0 120px rgba(212, 160, 23, 0.05), 0 30px 80px rgba(0, 0, 0, 0.3);
    transform: translateY(-6px);
  }

  .title-sponsor-badge {
    position: absolute;
    top: 1.5rem;
    right: -2.5rem;
    background: linear-gradient(135deg, var(--color-saffron), var(--color-gold-light), var(--color-amber));
    color: var(--color-cosmic);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
