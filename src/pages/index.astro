---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="The 18 Steps USA | Inauguration Ceremony - June 6, 2026">

  <!-- ===== HERO SECTION ===== -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img
        src={`${base}images/aesthetic/main_vishnu.webp`}
        alt="Divine backdrop"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-cosmic/70 via-cosmic/50 to-cosmic"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-cosmic/60 to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto pt-20">
      <div class="animate-fade-in">
        <img
          src={`${base}images/aesthetic/the_18_steps_logo.jpg`}
          alt="The 18 Steps Logo"
          class="w-28 h-28 md:w-36 md:h-36 rounded-full mx-auto mb-8 border-4 border-saffron/60 shadow-2xl shadow-saffron/20 animate-glow"
        />
      </div>

      <p class="text-saffron/80 text-sm md:text-base tracking-[0.3em] uppercase mb-4 animate-slide-up font-medium">
        Inaugurating the USA Chapter
      </p>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold mb-6 animate-slide-up text-gradient-gold leading-tight">
        The 18 Steps
      </h1>

      <p class="font-serif text-xl md:text-2xl text-cream/80 italic mb-2 animate-slide-up">
        Preserving Dharma, Heritage and Humanity
      </p>

      <div class="gold-divider"></div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10 animate-slide-up">
        <p class="text-cream/70 text-lg">
          <span class="text-saffron font-semibold">June 6, 2026</span> &middot; Placentia, California
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8 animate-slide-up">
        <a href="#rsvp" class="btn-primary text-lg px-10 py-4">RSVP Now</a>
        <a href="#about" class="btn-outline text-lg px-10 py-4">Learn More</a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-float">
        <svg class="w-6 h-6 text-saffron/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- ===== COUNTDOWN SECTION ===== -->
  <section class="py-16 bg-gradient-to-b from-cosmic to-cosmic-light/30 bg-pattern-mandala">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-saffron/80 text-sm tracking-[0.3em] uppercase mb-4">The Countdown Begins</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6" id="countdown">
        <div class="card-dark text-center">
          <span class="text-4xl md:text-5xl font-display font-bold text-gradient-gold" id="days">--</span>
          <p class="text-cream/60 text-sm tracking-wider uppercase mt-2">Days</p>
        </div>
        <div class="card-dark text-center">
          <span class="text-4xl md:text-5xl font-display font-bold text-gradient-gold" id="hours">--</span>
          <p class="text-cream/60 text-sm tracking-wider uppercase mt-2">Hours</p>
        </div>
        <div class="card-dark text-center">
          <span class="text-4xl md:text-5xl font-display font-bold text-gradient-gold" id="minutes">--</span>
          <p class="text-cream/60 text-sm tracking-wider uppercase mt-2">Minutes</p>
        </div>
        <div class="card-dark text-center">
          <span class="text-4xl md:text-5xl font-display font-bold text-gradient-gold" id="seconds">--</span>
          <p class="text-cream/60 text-sm tracking-wider uppercase mt-2">Seconds</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT THE 18 STEPS ===== -->
  <section id="about" class="py-24 bg-cosmic">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-4xl md:text-5xl">About The 18 Steps</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <img
            src={`${base}images/aesthetic/krishna.jpg`}
            alt="Krishna - Divine Wisdom"
            class="rounded-lg shadow-2xl shadow-saffron/10 border border-saffron/20 w-full"
          />
        </div>
        <div>
          <p class="text-cream/80 text-lg leading-relaxed mb-6 font-serif">
            The 18 Steps was born from a deep commitment to preserving and sharing the timeless wisdom of Sanatana Dharma. Inspired by the profound teachings of Sharath A Haridasan, we strive to bring knowledge, tradition, and service together.
          </p>
          <p class="text-cream/70 leading-relaxed mb-6">
            The 18 Steps USA strives to bring these values to American shores. Through lectures, courses, workshops, and digital initiatives, we make spiritual and historical knowledge accessible to seekers worldwide.
          </p>
          <p class="text-cream/70 leading-relaxed">
            Beyond education, we actively engage in heritage conservation, temple renovation, Vedic studies, and humanitarian efforts, ensuring that the light of Dharma continues to shine for generations to come.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MENTOR SECTION ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-saffron/80 text-sm tracking-[0.3em] uppercase mb-2">Our Guiding Light</p>
        <h2 class="section-title text-4xl md:text-5xl">Sharath A Haridasan</h2>
        <div class="gold-divider"></div>
        <p class="section-subtitle mt-4">Filmmaker, Scholar, Spiritual Teacher</p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <p class="text-cream/80 text-lg leading-relaxed mb-6 font-serif">
            A filmmaker, producer and writer by profession, Sharath A Haridasan is a scholar, speaker, and passionate educator who has dedicated his life to unraveling the depths of Sanatana Dharma, rituals, literature, and history.
          </p>
          <p class="text-cream/70 leading-relaxed mb-6">
            His lectures and discourses bring the essence of sadhana, philosophy, and spiritual practices to seekers in a way that is both profound and practical. Through The 18 Steps, he continues to guide and inspire thousands on their spiritual journey.
          </p>
          <p class="text-cream/70 leading-relaxed italic border-l-2 border-saffron/40 pl-6">
            "A spiritual teacher, Vedic speaker, author, and filmmaker who blends ancient wisdom with modern insights. Through poetic expression, he guides individuals towards a life of purpose, prosperity, and spiritual depth."
          </p>
        </div>
        <div class="order-1 md:order-2 grid grid-cols-1 gap-6">
          <img
            src={`${base}images/aesthetic/sharath_a_haridasan_1.jpg`}
            alt="Sharath A Haridasan speaking"
            class="rounded-lg shadow-2xl shadow-saffron/10 border border-saffron/20 w-full"
          />
          <img
            src={`${base}images/aesthetic/sharath_a_haridasan_2.jpg`}
            alt="Sharath A Haridasan"
            class="rounded-lg shadow-2xl shadow-saffron/10 border border-saffron/20 w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EVENT DETAILS ===== -->
  <section id="event" class="py-24 bg-cosmic relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern-mandala opacity-50"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="section-title text-4xl md:text-5xl">Inauguration Event</h2>
        <div class="gold-divider"></div>
        <p class="section-subtitle mt-4">Opening Chapter in USA</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Event Poster -->
        <div>
          <img
            src={`${base}images/event/1.jpg`}
            alt="The 18 Steps Inauguration Event Poster"
            class="rounded-lg shadow-2xl shadow-saffron/10 border border-saffron/20 w-full"
          />
        </div>

        <!-- Event Info Cards -->
        <div class="space-y-6">
          <div class="card-dark flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-saffron/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="text-saffron font-semibold text-lg">Date & Time</h3>
              <p class="text-cream/80">June 6, 2026 &middot; Saturday</p>
              <p class="text-cream/60">2:00 PM - 8:00 PM</p>
            </div>
          </div>

          <div class="card-dark flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-saffron/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-saffron font-semibold text-lg">Venue</h3>
              <p class="text-cream/80">PYLUSD Performing Arts Center</p>
              <p class="text-cream/60">1651 Valencia Ave, Placentia, CA 92870</p>
            </div>
          </div>

          <div class="card-dark flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-saffron/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-saffron font-semibold text-lg">Event Highlights</h3>
              <ul class="text-cream/70 text-sm space-y-1 mt-1">
                <li>300-400+ attendees from across the country</li>
                <li>Non-ticketed community event</li>
                <li>Professionally catered dinner included</li>
                <li>First professional dance drama in LA after 10 years</li>
                <li>Representatives from cultural organizations across the USA</li>
              </ul>
            </div>
          </div>

          <div class="card-dark flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-saffron/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div>
              <h3 class="text-saffron font-semibold text-lg">Venue Highlights</h3>
              <ul class="text-cream/70 text-sm space-y-1 mt-1">
                <li>Fully equipped theatrical stage with professional lighting & sound</li>
                <li>Massive LED wall backdrop (24' x 10')</li>
                <li>Comfortable auditorium seating</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CHAAYAMUKHI TEASER ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic-light/20 to-cosmic relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-saffron/80 text-sm tracking-[0.3em] uppercase mb-2">Featured Performance</p>
        <h2 class="section-title text-4xl md:text-5xl">Chaayamukhi</h2>
        <div class="gold-divider"></div>
        <p class="section-subtitle mt-4">A Mirror of Desire, A Promise to Nature</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <img src={`${base}images/chayamughi/1.jpg`} alt="Chaayamukhi - Dance" class="rounded-lg shadow-xl border border-saffron/20 w-full h-80 object-cover" />
        <img src={`${base}images/chayamughi/2.jpg`} alt="Chaayamukhi - Action" class="rounded-lg shadow-xl border border-saffron/20 w-full h-80 object-cover" />
        <img src={`${base}images/chayamughi/3.jpg`} alt="Chaayamukhi - Battle" class="rounded-lg shadow-xl border border-saffron/20 w-full h-80 object-cover" />
      </div>

      <div class="card-dark max-w-3xl mx-auto text-center">
        <p class="text-cream/80 text-lg leading-relaxed font-serif mb-6">
          A mesmerizing musical dance drama &mdash; a reflective journey into the self, inspired by the timeless philosophy of "Thathwamasi". The production features a powerful blend of Indian classical and folk dance, supported by folk-style music, exploring our deep connection with Mother Earth.
        </p>
        <p class="text-cream/60 mb-8">
          Featuring approximately 40 performers with Kalari-inspired stunt choreography, professional audio-visual production, and studio-quality narration.
        </p>
        <a href={`${base}chaayamukhi`} class="btn-primary">Discover Chaayamukhi</a>
      </div>
    </div>
  </section>

  <!-- ===== RAFFLE SECTION ===== -->
  <section class="py-24 bg-cosmic relative">
    <div class="absolute inset-0 bg-pattern-mandala opacity-30"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <h2 class="section-title text-4xl md:text-5xl">Win Big!</h2>
        <div class="gold-divider"></div>
        <p class="section-subtitle mt-4 mb-12">Exciting Raffle Draw at the Event</p>

        <div class="card-dark max-w-2xl mx-auto animate-glow">
          <div class="text-center">
            <svg class="w-16 h-16 text-saffron mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
            </svg>
            <h3 class="text-3xl md:text-4xl font-display font-bold text-gradient-gold mb-4">$1,500</h3>
            <p class="text-cream/80 text-xl mb-2">in Gift Vouchers</p>
            <p class="text-cream/60">
              Every attendee gets a chance to win! Raffle draw will be held during the inauguration event. You must be present to win.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMMITTEE SECTION ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-4xl md:text-5xl">Our Committee</h2>
        <div class="gold-divider"></div>
        <p class="section-subtitle mt-4">The dedicated team behind the inauguration</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { name: 'Committee Member', role: 'President' },
          { name: 'Committee Member', role: 'Vice President' },
          { name: 'Committee Member', role: 'Secretary' },
          { name: 'Committee Member', role: 'Treasurer' },
          { name: 'Committee Member', role: 'Event Coordinator' },
          { name: 'Committee Member', role: 'Cultural Director' },
          { name: 'Committee Member', role: 'PR & Outreach' },
          { name: 'Committee Member', role: 'Volunteer Lead' },
        ].map((member) => (
          <div class="card-dark text-center group hover:border-saffron/40 transition-all duration-300">
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-saffron/30 to-royal/30 mx-auto mb-4 flex items-center justify-center">
              <svg class="w-10 h-10 text-saffron/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="text-cream font-semibold text-sm">{member.name}</h3>
            <p class="text-saffron/70 text-xs tracking-wider uppercase mt-1">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RSVP SECTION ===== -->
  <section id="rsvp" class="py-24 bg-cosmic relative">
    <div class="absolute inset-0 bg-pattern-mandala opacity-30"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-12">
        <h2 class="section-title text-4xl md:text-5xl">RSVP</h2>
        <div class="gold-divider"></div>
        <p class="section-subtitle mt-4">Reserve your spot at the inauguration</p>
      </div>

      <form class="card-dark space-y-6" id="rsvp-form">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-saffron/80 text-sm tracking-wider uppercase mb-2">Full Name *</label>
            <input
              type="text"
              required
              class="w-full bg-cosmic/60 border border-saffron/20 rounded px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-saffron/60 transition-colors"
              placeholder="Enter your name"
            />
          </div>
          <div>
            <label class="block text-saffron/80 text-sm tracking-wider uppercase mb-2">Email *</label>
            <input
              type="email"
              required
              class="w-full bg-cosmic/60 border border-saffron/20 rounded px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-saffron/60 transition-colors"
              placeholder="Enter your email"
            />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-saffron/80 text-sm tracking-wider uppercase mb-2">Phone</label>
            <input
              type="tel"
              class="w-full bg-cosmic/60 border border-saffron/20 rounded px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-saffron/60 transition-colors"
              placeholder="Enter your phone number"
            />
          </div>
          <div>
            <label class="block text-saffron/80 text-sm tracking-wider uppercase mb-2">Number of Guests</label>
            <select class="w-full bg-cosmic/60 border border-saffron/20 rounded px-4 py-3 text-cream focus:outline-none focus:border-saffron/60 transition-colors">
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5+">5+</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-saffron/80 text-sm tracking-wider uppercase mb-2">Special Requirements</label>
          <textarea
            rows="3"
            class="w-full bg-cosmic/60 border border-saffron/20 rounded px-4 py-3 text-cream placeholder-cream/30 focus:outline-none focus:border-saffron/60 transition-colors resize-none"
            placeholder="Any dietary restrictions, accessibility needs, etc."
          ></textarea>
        </div>

        <div class="text-center">
          <button type="submit" class="btn-primary text-lg px-12 py-4">
            Submit RSVP
          </button>
          <p class="text-cream/40 text-xs mt-4">
            * RSVP submission is currently for display purposes. Full functionality coming soon.
          </p>
        </div>
      </form>
    </div>
  </section>

  <!-- ===== CONTACT SECTION ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-title text-4xl md:text-5xl">Get In Touch</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-3 gap-8 mt-12">
        <div class="card-dark">
          <svg class="w-10 h-10 text-saffron mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <h3 class="text-saffron font-semibold mb-2">Email</h3>
          <a href="mailto:info@the18stepsusa.org" class="text-cream/70 hover:text-saffron transition-colors text-sm">info@the18stepsusa.org</a>
        </div>

        <div class="card-dark">
          <svg class="w-10 h-10 text-saffron mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <h3 class="text-saffron font-semibold mb-2">Venue</h3>
          <p class="text-cream/70 text-sm">PYLUSD Performing Arts Center<br/>1651 Valencia Ave<br/>Placentia, CA 92870</p>
        </div>

        <div class="card-dark">
          <svg class="w-10 h-10 text-saffron mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="text-saffron font-semibold mb-2">Event Time</h3>
          <p class="text-cream/70 text-sm">Saturday, June 6, 2026<br/>2:00 PM - 8:00 PM PST</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Countdown Timer
  function updateCountdown() {
    const eventDate = new Date('2026-06-06T14:00:00-07:00').getTime();
    const now = new Date().getTime();
    const diff = eventDate - now;

    if (diff <= 0) {
      document.getElementById('days')!.textContent = '0';
      document.getElementById('hours')!.textContent = '0';
      document.getElementById('minutes')!.textContent = '0';
      document.getElementById('seconds')!.textContent = '0';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    document.getElementById('days')!.textContent = String(days);
    document.getElementById('hours')!.textContent = String(hours).padStart(2, '0');
    document.getElementById('minutes')!.textContent = String(minutes).padStart(2, '0');
    document.getElementById('seconds')!.textContent = String(seconds).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // RSVP form (front-end only)
  document.getElementById('rsvp-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you for your RSVP! We will confirm your reservation soon.');
  });
</script>
