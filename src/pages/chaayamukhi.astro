---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Chaayamukhi - Musical Dance Drama | The 18 Steps USA">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}/images/chayamughi/2.jpg`} alt="Chaayamukhi" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-cosmic/80 via-cosmic/60 to-cosmic"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-24">
      <p class="text-saffron/80 text-sm tracking-[0.3em] uppercase mb-4">Musical Dance Drama</p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-gradient-gold mb-6">Chaayamukhi</h1>
      <p class="font-serif text-xl md:text-2xl text-cream/80 italic">A Mirror of Desire, A Promise to Nature</p>
      <div class="gold-divider"></div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="py-24 bg-cosmic">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-title text-3xl md:text-4xl">The Story</h2>
          <div class="gold-divider !mx-0"></div>
          <p class="text-cream/80 text-lg leading-relaxed mb-6 font-serif mt-6">
            A reflective journey into the self, inspired by the timeless philosophy of "Thathwamasi" &mdash; <em>Thou art that</em>.
          </p>
          <p class="text-cream/70 leading-relaxed mb-6">
            The production features a powerful blend of Indian classical and folk dance, supported by folk-style music. Chaayamukhi explores our deep connection with Mother Earth and reminds us that the divine message we seek outside lives within us.
          </p>
          <p class="text-cream/70 leading-relaxed">
            A collective of passionate artists driven by the power of visual storytelling, crafting immersive narratives that speak through movement, imagery, and emotion.
          </p>
        </div>
        <div>
          <img src={`${base}/images/chayamughi/1.jpg`} alt="Chaayamukhi dancers" class="rounded-lg shadow-2xl shadow-saffron/10 border border-saffron/20 w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== IMAGE GALLERY ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-3xl md:text-4xl">Gallery</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="group overflow-hidden rounded-lg border border-saffron/20">
          <img src={`${base}/images/chayamughi/1.jpg`} alt="Chaayamukhi performance" class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-700" />
        </div>
        <div class="group overflow-hidden rounded-lg border border-saffron/20">
          <img src={`${base}/images/chayamughi/2.jpg`} alt="Chaayamukhi warrior" class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-700" />
        </div>
        <div class="group overflow-hidden rounded-lg border border-saffron/20">
          <img src={`${base}/images/chayamughi/3.jpg`} alt="Chaayamukhi battle" class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-700" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CAST & CREW ===== -->
  <section class="py-24 bg-cosmic">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-title text-3xl md:text-4xl">Cast & Crew</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          'Approximately 40 performers, including children and adults',
          'Professional dancers and experienced dance choreographers',
          'Kalari-inspired stunt choreography integrated into dance sequences',
          'Professionally recorded audio track',
          'Studio-quality voice-over narration',
          'Professional audio-visual production',
          'Director and Art Director overseeing stage aesthetics',
          'Cinematographer and in-house professional equipment',
        ].map((item) => (
          <div class="flex items-start gap-4">
            <div class="w-2 h-2 rounded-full bg-saffron mt-2 flex-shrink-0"></div>
            <p class="text-cream/80">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PAST PERFORMANCES ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-title text-3xl md:text-4xl">Past Performances</h2>
      <div class="gold-divider"></div>

      <div class="card-dark max-w-2xl mx-auto mt-12">
        <h3 class="text-saffron font-display text-xl font-semibold mb-2">KHNA National Convention</h3>
        <p class="text-cream/70 mb-4">Atlantic City, NJ &middot; Engaged 1,000+ Audience</p>
        <blockquote class="text-cream/60 italic border-l-2 border-saffron/40 pl-6 text-left">
          "Chaayamukhi is a visually stunning and emotionally powerful production. The storytelling and presentation left a lasting impact on the audience."
          <cite class="block text-saffron/60 text-sm mt-2 not-italic">&mdash; Audience reaction</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ===== VIDEOS ===== -->
  <section class="py-24 bg-cosmic">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-title text-3xl md:text-4xl">Videos</h2>
      <div class="gold-divider"></div>
      <p class="text-cream/60 mt-8 mb-8">Videos coming soon. Stay tuned for trailers and behind-the-scenes footage.</p>

      <div class="card-dark flex items-center justify-center h-64">
        <div class="text-center">
          <svg class="w-16 h-16 text-saffron/40 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-cream/40 text-sm">Video content will be available soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL MEDIA ===== -->
  <section class="py-24 bg-gradient-to-b from-cosmic to-cosmic-light/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-title text-3xl md:text-4xl">Follow Us</h2>
      <div class="gold-divider"></div>
      <p class="text-cream/60 mt-4 mb-12">Stay connected with Chaayamukhi on social media</p>

      <div class="flex items-center justify-center gap-8">
        <a href="#" class="group" aria-label="YouTube">
          <div class="w-16 h-16 rounded-full border-2 border-saffron/30 flex items-center justify-center group-hover:border-saffron group-hover:bg-saffron/10 transition-all">
            <svg class="w-7 h-7 text-saffron/60 group-hover:text-saffron transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
        </a>
        <a href="#" class="group" aria-label="Instagram">
          <div class="w-16 h-16 rounded-full border-2 border-saffron/30 flex items-center justify-center group-hover:border-saffron group-hover:bg-saffron/10 transition-all">
            <svg class="w-7 h-7 text-saffron/60 group-hover:text-saffron transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
        </a>
        <a href="#" class="group" aria-label="Facebook">
          <div class="w-16 h-16 rounded-full border-2 border-saffron/30 flex items-center justify-center group-hover:border-saffron group-hover:bg-saffron/10 transition-all">
            <svg class="w-7 h-7 text-saffron/60 group-hover:text-saffron transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-24 bg-cosmic relative">
    <div class="absolute inset-0 bg-pattern-mandala opacity-30"></div>
    <div class="max-w-3xl mx-auto px-4 text-center relative z-10">
      <h2 class="section-title text-3xl md:text-4xl">Experience Chaayamukhi Live</h2>
      <div class="gold-divider"></div>
      <p class="text-cream/70 text-lg mt-6 mb-10">
        Join us at the PYLUSD Performing Arts Center on June 6, 2026 for an unforgettable evening of art, culture, and spiritual exploration.
      </p>
      <a href={`${base}/#rsvp`} class="btn-primary text-lg px-12 py-4">RSVP for the Event</a>
    </div>
  </section>

</Layout>
