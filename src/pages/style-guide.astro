---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const colors = [
  { name: 'Cosmic', token: '--color-cosmic', hex: '#0d0d2b', tailwind: 'bg-cosmic', usage: 'Primary background, dark base' },
  { name: 'Cosmic Light', token: '--color-cosmic-light', hex: '#1a1a4e', tailwind: 'bg-cosmic-light', usage: 'Secondary background, cards, overlays' },
  { name: 'Saffron', token: '--color-saffron', hex: '#d4a017', tailwind: 'bg-saffron', usage: 'Primary brand accent, buttons, headlines' },
  { name: 'Gold Light', token: '--color-gold-light', hex: '#f0c040', tailwind: 'bg-gold-light', usage: 'Hover states, highlights, secondary gold' },
  { name: 'Amber', token: '--color-amber', hex: '#b8860b', tailwind: 'bg-amber', usage: 'Warm accent, gradient endpoint' },
  { name: 'Royal', token: '--color-royal', hex: '#4a2080', tailwind: 'bg-royal', usage: 'Purple accent, decorative elements' },
  { name: 'Purple Soft', token: '--color-purple-soft', hex: '#6b3fa0', tailwind: 'bg-purple-soft', usage: 'Soft purple, secondary decorative' },
  { name: 'Celestial', token: '--color-celestial', hex: '#3d7cc9', tailwind: 'bg-celestial', usage: 'Blue accent, links, informational' },
  { name: 'Crimson', token: '--color-crimson', hex: '#8b1a1a', tailwind: 'bg-crimson', usage: 'Deep red accent, warnings, emphasis' },
  { name: 'Cream', token: '--color-cream', hex: '#f5f0e8', tailwind: 'bg-cream', usage: 'Primary text color, light surfaces' },
];

const fonts = [
  {
    name: 'Cinzel',
    token: '--font-display',
    tailwind: 'font-display',
    weights: [400, 500, 600, 700, 800, 900],
    usage: 'Headlines, page titles, section headings, display text',
    sample: 'The 18 Steps USA',
    source: 'Google Fonts',
  },
  {
    name: 'Playfair Display',
    token: '--font-serif',
    tailwind: 'font-serif',
    weights: [400, 500, 600, 700],
    hasItalic: true,
    usage: 'Elegant descriptions, taglines, quotes, body emphasis',
    sample: 'Preserving Dharma, Heritage and Humanity',
    source: 'Google Fonts',
  },
  {
    name: 'Inter',
    token: '--font-sans',
    tailwind: 'font-sans',
    weights: [300, 400, 500, 600, 700],
    usage: 'Body text, navigation, UI elements, form inputs',
    sample: 'The quick brown fox jumps over the lazy dog.',
    source: 'Google Fonts',
  },
];

const typeSizes = [
  { label: 'Display XL', classes: 'text-5xl md:text-7xl', font: 'font-display', px: '48px / 72px', usage: 'Hero headlines' },
  { label: 'Display LG', classes: 'text-4xl md:text-5xl', font: 'font-display', px: '36px / 48px', usage: 'Page titles' },
  { label: 'Heading 1', classes: 'text-3xl md:text-4xl', font: 'font-display', px: '30px / 36px', usage: 'Section titles' },
  { label: 'Heading 2', classes: 'text-2xl md:text-3xl', font: 'font-display', px: '24px / 30px', usage: 'Sub-section titles' },
  { label: 'Heading 3', classes: 'text-xl md:text-2xl', font: 'font-serif', px: '20px / 24px', usage: 'Card titles, feature headings' },
  { label: 'Heading 4', classes: 'text-lg', font: 'font-serif', px: '18px', usage: 'Small headings, labels' },
  { label: 'Body Large', classes: 'text-lg', font: 'font-sans', px: '18px', usage: 'Lead paragraphs, emphasis text' },
  { label: 'Body', classes: 'text-base', font: 'font-sans', px: '16px', usage: 'Default body text' },
  { label: 'Body Small', classes: 'text-sm', font: 'font-sans', px: '14px', usage: 'Secondary text, captions' },
  { label: 'Caption', classes: 'text-xs', font: 'font-sans', px: '12px', usage: 'Labels, metadata, fine print' },
];
---

<Layout title="Style Guide - The 18 Steps USA">
  <!-- Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern-mandala opacity-30"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h1 class="font-display text-4xl md:text-6xl font-bold text-gradient-gold mb-6 tracking-wider">
        STYLE GUIDE
      </h1>
      <div class="gold-divider"></div>
      <p class="font-serif text-xl text-cream/80 max-w-2xl mx-auto mt-6 italic">
        The official aesthetic reference for all multimedia content created for The 18 Steps USA
      </p>
    </div>
  </section>

  <!-- Brand Identity -->
  <section id="brand-identity" class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">BRAND IDENTITY</h2>
      <div class="gold-divider"></div>
      <div class="mt-12 grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="font-display text-xl text-saffron mb-4 tracking-wider">BRAND ESSENCE</h3>
          <p class="text-cream/80 leading-relaxed mb-6">
            The 18 Steps USA visual identity draws from the sacred and cosmic — blending deep cosmic navy backgrounds
            with radiant saffron and gold accents. The aesthetic evokes ancient wisdom meeting modern elegance,
            reflecting the organization's mission of preserving Dharma, heritage, and humanity.
          </p>
          <div class="space-y-3 text-sm">
            <div class="flex items-start gap-3">
              <span class="text-saffron font-display font-bold mt-0.5">01</span>
              <p class="text-cream/70"><strong class="text-cream">Mood:</strong> Sacred, cosmic, regal, warm</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-saffron font-display font-bold mt-0.5">02</span>
              <p class="text-cream/70"><strong class="text-cream">Tone:</strong> Dignified, inviting, spiritual, timeless</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-saffron font-display font-bold mt-0.5">03</span>
              <p class="text-cream/70"><strong class="text-cream">Keywords:</strong> Dharma, heritage, humanity, sacred art, tradition</p>
            </div>
          </div>
        </div>
        <div class="card-dark text-center p-8">
          <img
            src={`${base}/images/aesthetic/the_18_steps_logo.jpg`}
            alt="The 18 Steps Logo"
            class="w-40 h-40 rounded-full border-4 border-saffron/50 mx-auto mb-6"
          />
          <p class="font-display text-2xl text-saffron tracking-[0.2em] font-semibold">THE 18 STEPS</p>
          <p class="text-cream/60 tracking-[0.3em] text-xs mt-1">USA</p>
          <p class="font-serif italic text-cream/70 text-sm mt-3">Preserving Dharma, Heritage and Humanity</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Color Palette -->
  <section id="color-palette" class="py-16 bg-cosmic-light/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">COLOR PALETTE</h2>
      <div class="gold-divider"></div>
      <p class="text-center text-cream/70 mt-4 mb-12 max-w-2xl mx-auto">
        All brand colors with their hex values, CSS tokens, and intended usage.
        Use these exact values across all multimedia content to maintain visual consistency.
      </p>

      <!-- Primary Colors -->
      <h3 class="font-display text-lg text-cream tracking-wider mb-6">PRIMARY COLORS</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-12">
        {colors.slice(0, 5).map(color => (
          <div class="group">
            <div
              class="h-28 rounded-t-lg border border-saffron/10 relative overflow-hidden"
              style={`background-color: ${color.hex};`}
            >
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                <span class="text-white font-mono text-sm font-bold">{color.hex}</span>
              </div>
            </div>
            <div class="bg-cosmic-light/60 border border-t-0 border-saffron/10 rounded-b-lg p-3">
              <p class="font-display text-sm text-saffron font-semibold">{color.name}</p>
              <p class="text-cream/50 text-xs font-mono mt-1">{color.hex}</p>
              <p class="text-cream/40 text-xs mt-1">{color.usage}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Secondary Colors -->
      <h3 class="font-display text-lg text-cream tracking-wider mb-6">SECONDARY COLORS</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-12">
        {colors.slice(5).map(color => (
          <div class="group">
            <div
              class="h-28 rounded-t-lg border border-saffron/10 relative overflow-hidden"
              style={`background-color: ${color.hex};`}
            >
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                <span class="text-white font-mono text-sm font-bold">{color.hex}</span>
              </div>
            </div>
            <div class="bg-cosmic-light/60 border border-t-0 border-saffron/10 rounded-b-lg p-3">
              <p class="font-display text-sm text-saffron font-semibold">{color.name}</p>
              <p class="text-cream/50 text-xs font-mono mt-1">{color.hex}</p>
              <p class="text-cream/40 text-xs mt-1">{color.usage}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Color Usage Guidelines -->
      <div class="card-dark mt-8">
        <h3 class="font-display text-lg text-saffron tracking-wider mb-4">COLOR USAGE RULES</h3>
        <div class="grid md:grid-cols-2 gap-6 text-sm text-cream/70">
          <div>
            <p class="text-cream font-semibold mb-2">Background Hierarchy</p>
            <ul class="space-y-1">
              <li>Primary background: <span class="font-mono text-saffron/80">Cosmic #0d0d2b</span></li>
              <li>Secondary / cards: <span class="font-mono text-saffron/80">Cosmic Light #1a1a4e</span> at 60% opacity</li>
              <li>Overlays: <span class="font-mono text-saffron/80">Cosmic</span> at 95% with backdrop blur</li>
            </ul>
          </div>
          <div>
            <p class="text-cream font-semibold mb-2">Accent Usage</p>
            <ul class="space-y-1">
              <li>Primary accent: <span class="font-mono text-saffron/80">Saffron #d4a017</span></li>
              <li>Hover states: <span class="font-mono text-saffron/80">Gold Light #f0c040</span></li>
              <li>Borders: <span class="font-mono text-saffron/80">Saffron</span> at 20-40% opacity</li>
              <li>Text selection: <span class="font-mono text-saffron/80">Saffron</span> background, <span class="font-mono text-saffron/80">Cosmic</span> text</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Color Contrast Pairings -->
      <div class="mt-8">
        <h3 class="font-display text-lg text-cream tracking-wider mb-6">RECOMMENDED PAIRINGS</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="rounded-lg overflow-hidden border border-saffron/10">
            <div class="bg-cosmic p-6 text-center">
              <p class="text-saffron font-display text-lg font-bold">Saffron on Cosmic</p>
              <p class="text-cream/60 text-xs mt-1">Primary heading treatment</p>
            </div>
          </div>
          <div class="rounded-lg overflow-hidden border border-saffron/10">
            <div class="p-6 text-center" style="background-color: #d4a017;">
              <p class="font-display text-lg font-bold" style="color: #0d0d2b;">Cosmic on Saffron</p>
              <p class="text-xs mt-1" style="color: rgba(13,13,43,0.7);">Button text treatment</p>
            </div>
          </div>
          <div class="rounded-lg overflow-hidden border border-saffron/10">
            <div class="bg-cosmic p-6 text-center">
              <p class="text-cream font-sans text-lg">Cream on Cosmic</p>
              <p class="text-cream/60 text-xs mt-1">Body text treatment</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section id="typography" class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">TYPOGRAPHY</h2>
      <div class="gold-divider"></div>
      <p class="text-center text-cream/70 mt-4 mb-12 max-w-2xl mx-auto">
        Three typefaces form the typographic system — each serving a distinct role in the visual hierarchy.
      </p>

      <div class="space-y-8">
        {fonts.map(font => (
          <div class="card-dark">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="md:w-1/3">
                <h3 class="font-display text-xl text-saffron tracking-wider">{font.name.toUpperCase()}</h3>
                <p class="text-cream/50 text-xs font-mono mt-1">var({font.token})</p>
                <p class="text-cream/50 text-xs font-mono">Tailwind: {font.tailwind}</p>
                <p class="text-cream/50 text-xs mt-1">Source: {font.source}</p>
                <p class="text-cream/70 text-sm mt-3">{font.usage}</p>
                <div class="mt-3">
                  <p class="text-cream/50 text-xs mb-2">Available Weights:</p>
                  <div class="flex flex-wrap gap-2">
                    {font.weights.map(w => (
                      <span class="text-xs bg-saffron/10 text-saffron px-2 py-0.5 rounded">{w}</span>
                    ))}
                    {font.hasItalic && (
                      <span class="text-xs bg-purple-soft/20 text-purple-soft px-2 py-0.5 rounded">+ Italic</span>
                    )}
                  </div>
                </div>
              </div>
              <div class="md:w-2/3 space-y-3">
                {font.weights.map(w => (
                  <div class="flex items-baseline gap-4">
                    <span class="text-cream/40 text-xs font-mono w-12 shrink-0">{w}</span>
                    <p class={`${font.tailwind} text-2xl text-cream/90`} style={`font-weight: ${w};`}>
                      {font.sample}
                    </p>
                  </div>
                ))}
                {font.hasItalic && (
                  <div class="flex items-baseline gap-4">
                    <span class="text-cream/40 text-xs font-mono w-12 shrink-0">Italic</span>
                    <p class={`${font.tailwind} text-2xl text-cream/90 italic`}>
                      {font.sample}
                    </p>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Type Scale -->
  <section id="type-scale" class="py-16 bg-cosmic-light/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">TYPE SCALE</h2>
      <div class="gold-divider"></div>
      <p class="text-center text-cream/70 mt-4 mb-12 max-w-2xl mx-auto">
        The complete typographic scale with sizes, fonts, and usage context for consistent hierarchy.
      </p>

      <div class="space-y-6">
        {typeSizes.map(size => (
          <div class="card-dark flex flex-col md:flex-row md:items-center gap-4">
            <div class="md:w-1/4 shrink-0">
              <span class="text-saffron font-display text-sm font-semibold tracking-wider">{size.label}</span>
              <p class="text-cream/40 text-xs font-mono mt-1">{size.classes}</p>
              <p class="text-cream/40 text-xs font-mono">{size.px}</p>
              <p class="text-cream/50 text-xs mt-1">{size.usage}</p>
            </div>
            <div class="md:w-3/4">
              <p class={`${size.classes} ${size.font} text-cream/90 leading-tight`}>
                The 18 Steps USA
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Letter Spacing -->
      <div class="card-dark mt-12">
        <h3 class="font-display text-lg text-saffron tracking-wider mb-4">LETTER SPACING</h3>
        <div class="space-y-4">
          <div class="flex items-center gap-6">
            <span class="text-cream/40 text-xs font-mono w-32 shrink-0">tracking-wider (0.05em)</span>
            <p class="font-display text-lg text-cream tracking-wider">SECTION HEADINGS</p>
          </div>
          <div class="flex items-center gap-6">
            <span class="text-cream/40 text-xs font-mono w-32 shrink-0">tracking-widest (0.1em)</span>
            <p class="font-sans text-xs text-cream tracking-widest uppercase">LABELS &amp; METADATA</p>
          </div>
          <div class="flex items-center gap-6">
            <span class="text-cream/40 text-xs font-mono w-32 shrink-0">tracking-[0.2em]</span>
            <p class="font-display text-2xl text-saffron tracking-[0.2em] font-semibold">THE 18 STEPS</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos & Marks -->
  <section id="logos" class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">LOGOS &amp; MARKS</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-3 gap-8 mt-12">
        <!-- Primary Logo -->
        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-6">PRIMARY LOGO</h3>
          <div class="bg-cosmic rounded-lg p-8 mb-4">
            <img
              src={`${base}/images/aesthetic/the_18_steps_logo.jpg`}
              alt="Primary Logo"
              class="w-32 h-32 rounded-full border-4 border-saffron/50 mx-auto"
            />
          </div>
          <p class="text-cream/60 text-xs">Circular mark with saffron border</p>
          <p class="text-cream/40 text-xs mt-1">Min size: 48px &times; 48px</p>
        </div>

        <!-- Logo + Text Lockup -->
        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-6">LOGO + TEXT LOCKUP</h3>
          <div class="bg-cosmic rounded-lg p-8 mb-4">
            <div class="flex items-center gap-4 justify-center">
              <img
                src={`${base}/images/aesthetic/the_18_steps_logo.jpg`}
                alt="Logo Lockup"
                class="w-14 h-14 rounded-full border-2 border-saffron/50"
              />
              <div class="text-left">
                <p class="font-display text-lg text-saffron font-semibold tracking-wider">THE 18 STEPS</p>
                <p class="text-cream/60 tracking-[0.3em] text-xs">USA</p>
              </div>
            </div>
          </div>
          <p class="text-cream/60 text-xs">Horizontal lockup for navigation</p>
          <p class="text-cream/40 text-xs mt-1">Used in navbar and headers</p>
        </div>

        <!-- Text Only -->
        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-6">TEXT-ONLY MARK</h3>
          <div class="bg-cosmic rounded-lg p-8 mb-4 flex items-center justify-center min-h-[160px]">
            <div>
              <p class="font-display text-2xl text-saffron tracking-[0.2em] font-bold">THE 18 STEPS</p>
              <p class="text-cream/60 tracking-[0.3em] text-xs text-center mt-1">USA</p>
            </div>
          </div>
          <p class="text-cream/60 text-xs">Cinzel typeface, saffron color</p>
          <p class="text-cream/40 text-xs mt-1">For when logo image unavailable</p>
        </div>
      </div>

      <!-- Logo Clear Space -->
      <div class="card-dark mt-8">
        <h3 class="font-display text-lg text-saffron tracking-wider mb-4">LOGO GUIDELINES</h3>
        <div class="grid md:grid-cols-2 gap-6 text-sm text-cream/70">
          <div>
            <p class="text-cream font-semibold mb-2">Clear Space</p>
            <p>Maintain a minimum clear space equal to the height of the "18" text around all logo variations. No other elements should encroach on this space.</p>
          </div>
          <div>
            <p class="text-cream font-semibold mb-2">Logo Border</p>
            <p>The circular logo should always appear with a saffron-toned border at 50% opacity (<span class="font-mono text-saffron/80">border-saffron/50</span>). Border width: 2px for small, 4px for large.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Buttons & CTAs -->
  <section id="buttons" class="py-16 bg-cosmic-light/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">BUTTONS &amp; CTAs</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-2 gap-8 mt-12">
        <!-- Primary Button -->
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">PRIMARY BUTTON</h3>
          <div class="bg-cosmic rounded-lg p-8 flex items-center justify-center mb-4">
            <a href="#" class="btn-primary">RSVP Now</a>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1">
            <p>Class: <span class="text-saffron/80">.btn-primary</span></p>
            <p>Background: <span class="text-saffron/80">Saffron #d4a017</span></p>
            <p>Text: <span class="text-saffron/80">Cosmic #0d0d2b</span></p>
            <p>Padding: <span class="text-saffron/80">12px 32px</span></p>
            <p>Font weight: <span class="text-saffron/80">600</span></p>
            <p>Border radius: <span class="text-saffron/80">2px</span></p>
            <p>Letter spacing: <span class="text-saffron/80">0.05em</span></p>
            <p>Hover: <span class="text-saffron/80">Gold Light + scale(1.05) + shadow</span></p>
          </div>
        </div>

        <!-- Outline Button -->
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">OUTLINE BUTTON</h3>
          <div class="bg-cosmic rounded-lg p-8 flex items-center justify-center mb-4">
            <a href="#" class="btn-outline">Learn More</a>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1">
            <p>Class: <span class="text-saffron/80">.btn-outline</span></p>
            <p>Border: <span class="text-saffron/80">2px solid Saffron</span></p>
            <p>Text: <span class="text-saffron/80">Saffron #d4a017</span></p>
            <p>Padding: <span class="text-saffron/80">12px 32px</span></p>
            <p>Font weight: <span class="text-saffron/80">600</span></p>
            <p>Border radius: <span class="text-saffron/80">2px</span></p>
            <p>Letter spacing: <span class="text-saffron/80">0.05em</span></p>
            <p>Hover: <span class="text-saffron/80">Solid saffron bg, cosmic text</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cards & Containers -->
  <section id="cards" class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">CARDS &amp; CONTAINERS</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-2 gap-8 mt-12">
        <!-- Dark Card -->
        <div>
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">DARK CARD</h3>
          <div class="card-dark">
            <h4 class="font-display text-lg text-saffron mb-2">Card Title</h4>
            <p class="text-cream/70 text-sm">This is the standard card component used throughout the site for content grouping and visual separation.</p>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1 mt-4">
            <p>Class: <span class="text-saffron/80">.card-dark</span></p>
            <p>Background: <span class="text-saffron/80">rgba(26, 26, 78, 0.6)</span></p>
            <p>Backdrop: <span class="text-saffron/80">blur(8px)</span></p>
            <p>Border: <span class="text-saffron/80">1px solid rgba(212, 160, 23, 0.2)</span></p>
            <p>Border radius: <span class="text-saffron/80">0.5rem (8px)</span></p>
            <p>Padding: <span class="text-saffron/80">1.5rem (24px)</span></p>
          </div>
        </div>

        <!-- Section Title + Divider -->
        <div>
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">SECTION TITLE + DIVIDER</h3>
          <div class="card-dark text-center">
            <h4 class="section-title text-2xl">Section Title</h4>
            <div class="gold-divider"></div>
            <p class="text-cream/70 text-sm mt-4">Standard section heading pattern used across all pages.</p>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1 mt-4">
            <p>.section-title: <span class="text-saffron/80">Cinzel, 700, Saffron</span></p>
            <p>.gold-divider: <span class="text-saffron/80">96px × 2px</span></p>
            <p>Gradient: <span class="text-saffron/80">transparent → saffron → transparent</span></p>
            <p>Margin: <span class="text-saffron/80">1.5rem auto</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gradients & Effects -->
  <section id="gradients" class="py-16 bg-cosmic-light/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">GRADIENTS &amp; EFFECTS</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-2 gap-8 mt-12">
        <!-- Gold Text Gradient -->
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">GOLD TEXT GRADIENT</h3>
          <div class="bg-cosmic rounded-lg p-8 text-center mb-4">
            <p class="text-gradient-gold font-display text-4xl font-bold">GOLDEN TEXT</p>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1">
            <p>Class: <span class="text-saffron/80">.text-gradient-gold</span></p>
            <p>Direction: <span class="text-saffron/80">135deg</span></p>
            <p>Stops: <span class="text-saffron/80">Saffron → Gold Light → Amber</span></p>
            <p>CSS: <span class="text-saffron/80">background-clip: text</span></p>
          </div>
        </div>

        <!-- Mandala Pattern -->
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">MANDALA PATTERN</h3>
          <div class="bg-cosmic rounded-lg p-8 relative overflow-hidden mb-4" style="min-height: 120px;">
            <div class="absolute inset-0 bg-pattern-mandala opacity-60"></div>
            <div class="relative text-center">
              <p class="text-cream/60 text-sm">Subtle radial pattern overlay</p>
            </div>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1">
            <p>Class: <span class="text-saffron/80">.bg-pattern-mandala</span></p>
            <p>Pattern: <span class="text-saffron/80">radial-gradient, 100px tiles</span></p>
            <p>Color: <span class="text-saffron/80">Saffron at 5% opacity</span></p>
            <p>Usage: <span class="text-saffron/80">Section backgrounds at 30% opacity</span></p>
          </div>
        </div>

        <!-- Gold Divider Gradient -->
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">GOLD DIVIDER</h3>
          <div class="bg-cosmic rounded-lg p-8 text-center mb-4">
            <div class="gold-divider"></div>
            <div class="gold-divider" style="width: 12rem;"></div>
            <div class="gold-divider" style="width: 100%;"></div>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1">
            <p>Gradient: <span class="text-saffron/80">transparent → saffron → transparent</span></p>
            <p>Height: <span class="text-saffron/80">2px</span></p>
            <p>Default width: <span class="text-saffron/80">6rem (96px)</span></p>
          </div>
        </div>

        <!-- Glow Effect -->
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">GLOW EFFECT</h3>
          <div class="bg-cosmic rounded-lg p-8 flex items-center justify-center mb-4">
            <div class="w-24 h-24 rounded-full bg-saffron/20 animate-glow"></div>
          </div>
          <div class="text-xs text-cream/50 font-mono space-y-1">
            <p>Class: <span class="text-saffron/80">.animate-glow</span></p>
            <p>Shadow range: <span class="text-saffron/80">20px → 40px</span></p>
            <p>Color: <span class="text-saffron/80">Saffron at 30-60% opacity</span></p>
            <p>Duration: <span class="text-saffron/80">3s ease-in-out infinite</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Animations -->
  <section id="animations" class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">ANIMATIONS</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">FLOAT</h3>
          <div class="bg-cosmic rounded-lg p-6 mb-4 flex items-center justify-center" style="min-height: 100px;">
            <div class="w-12 h-12 bg-saffron/30 rounded-lg animate-float border border-saffron/40"></div>
          </div>
          <p class="text-cream/50 text-xs font-mono">.animate-float</p>
          <p class="text-cream/40 text-xs mt-1">6s ease-in-out infinite</p>
        </div>

        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">GLOW</h3>
          <div class="bg-cosmic rounded-lg p-6 mb-4 flex items-center justify-center" style="min-height: 100px;">
            <div class="w-12 h-12 bg-saffron/30 rounded-lg animate-glow border border-saffron/40"></div>
          </div>
          <p class="text-cream/50 text-xs font-mono">.animate-glow</p>
          <p class="text-cream/40 text-xs mt-1">3s ease-in-out infinite</p>
        </div>

        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">FADE IN</h3>
          <div class="bg-cosmic rounded-lg p-6 mb-4 flex items-center justify-center" style="min-height: 100px;">
            <div class="w-12 h-12 bg-saffron/30 rounded-lg animate-fade-in border border-saffron/40"></div>
          </div>
          <p class="text-cream/50 text-xs font-mono">.animate-fade-in</p>
          <p class="text-cream/40 text-xs mt-1">1s ease-out forwards</p>
        </div>

        <div class="card-dark text-center">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">SLIDE UP</h3>
          <div class="bg-cosmic rounded-lg p-6 mb-4 flex items-center justify-center" style="min-height: 100px;">
            <div class="w-12 h-12 bg-saffron/30 rounded-lg animate-slide-up border border-saffron/40"></div>
          </div>
          <p class="text-cream/50 text-xs font-mono">.animate-slide-up</p>
          <p class="text-cream/40 text-xs mt-1">0.8s ease-out forwards</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Spacing & Layout -->
  <section id="spacing" class="py-16 bg-cosmic-light/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title text-3xl text-center tracking-wider">SPACING &amp; LAYOUT</h2>
      <div class="gold-divider"></div>

      <div class="grid md:grid-cols-2 gap-8 mt-12">
        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">CONTAINER WIDTHS</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">max-w-6xl</span>
              <span class="text-cream/40 font-mono">1152px</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">max-w-7xl</span>
              <span class="text-cream/40 font-mono">1280px</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">max-w-2xl (content)</span>
              <span class="text-cream/40 font-mono">672px</span>
            </div>
          </div>
        </div>

        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">PAGE PADDING</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">Mobile (default)</span>
              <span class="text-cream/40 font-mono">px-4 (16px)</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">Tablet (sm:)</span>
              <span class="text-cream/40 font-mono">px-6 (24px)</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">Desktop (lg:)</span>
              <span class="text-cream/40 font-mono">px-8 (32px)</span>
            </div>
          </div>
        </div>

        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">SECTION SPACING</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">Section padding</span>
              <span class="text-cream/40 font-mono">py-16 (64px)</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">Hero top padding</span>
              <span class="text-cream/40 font-mono">pt-32 (128px)</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">Card gap</span>
              <span class="text-cream/40 font-mono">gap-8 (32px)</span>
            </div>
          </div>
        </div>

        <div class="card-dark">
          <h3 class="font-display text-sm text-saffron tracking-wider mb-4">BREAKPOINTS</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">sm (Small)</span>
              <span class="text-cream/40 font-mono">640px</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">md (Medium)</span>
              <span class="text-cream/40 font-mono">768px</span>
            </div>
            <div class="flex justify-between items-center border-b border-saffron/10 pb-2">
              <span class="text-cream/70">lg (Large)</span>
              <span class="text-cream/40 font-mono">1024px</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Reference Box -->
      <div class="card-dark mt-12">
        <h3 class="font-display text-lg text-saffron tracking-wider mb-4 text-center">QUICK REFERENCE FOR DESIGNERS</h3>
        <div class="grid md:grid-cols-3 gap-6 text-sm">
          <div>
            <p class="text-cream font-semibold mb-2">Print / Social Media</p>
            <ul class="text-cream/60 space-y-1">
              <li>Background: <span class="font-mono">#0d0d2b</span></li>
              <li>Primary text: <span class="font-mono">#f5f0e8</span></li>
              <li>Accent: <span class="font-mono">#d4a017</span></li>
              <li>Headline font: Cinzel</li>
              <li>Body font: Inter</li>
            </ul>
          </div>
          <div>
            <p class="text-cream font-semibold mb-2">Video / Motion</p>
            <ul class="text-cream/60 space-y-1">
              <li>Background: <span class="font-mono">#0d0d2b</span></li>
              <li>Lower thirds: Saffron gold bar</li>
              <li>Title font: Cinzel Bold</li>
              <li>Subtitle font: Playfair Display Italic</li>
              <li>Transitions: Fade in, 1s ease-out</li>
            </ul>
          </div>
          <div>
            <p class="text-cream font-semibold mb-2">Presentation</p>
            <ul class="text-cream/60 space-y-1">
              <li>Slide bg: <span class="font-mono">#0d0d2b</span></li>
              <li>Headings: Cinzel in <span class="font-mono">#d4a017</span></li>
              <li>Body: Inter in <span class="font-mono">#f5f0e8</span></li>
              <li>Accents: Gold gradients</li>
              <li>Dividers: Gold fade lines</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
