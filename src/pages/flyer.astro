---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tri-Fold Flyer - The 18 Steps USA</title>
    <link rel="icon" type="image/jpeg" href={`${base}/images/aesthetic/the_18_steps_logo.jpg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #0d0d2b;
        color: #f5f0e8;
      }

      /* ===== CONTROLS ===== */
      .screen-controls {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: rgba(13,13,43,0.97);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(212,160,23,0.3);
        padding: 12px 24px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .screen-controls h1 { font-family: 'Cinzel', serif; color: #d4a017; font-size: 14px; letter-spacing: 0.1em; }
      .screen-controls .btn-group { display: flex; gap: 8px; }
      .screen-controls button, .screen-controls a.ctrl-link {
        padding: 6px 16px; border: 1px solid rgba(212,160,23,0.4);
        background: transparent; color: #d4a017;
        font-family: 'Inter', sans-serif; font-size: 12px;
        cursor: pointer; transition: all 0.2s; letter-spacing: 0.05em;
        text-decoration: none; display: inline-flex; align-items: center;
      }
      .screen-controls button:hover, .screen-controls button.active,
      .screen-controls a.ctrl-link:hover { background: #d4a017; color: #0d0d2b; }

      .screen-label {
        text-align: center; font-family: 'Cinzel', serif;
        color: rgba(212,160,23,0.4); font-size: 11px;
        letter-spacing: 0.2em; margin: 10px 0 20px;
      }
      .back-to-site { text-align: center; margin: 30px 0 60px; }
      .back-to-site a {
        color: #d4a017; font-size: 12px; text-decoration: none;
        border: 1px solid rgba(212,160,23,0.3); padding: 8px 24px;
        transition: all 0.2s; font-family: 'Inter', sans-serif; letter-spacing: 0.05em;
      }
      .back-to-site a:hover { background: #d4a017; color: #0d0d2b; }

      /* ===== FLYER ===== */
      .flyer-page {
        width: 11in; height: 8.5in;
        position: relative; overflow: hidden;
        margin: 80px auto 40px;
        box-shadow: 0 20px 80px rgba(0,0,0,0.6);
        background: #0d0d2b;
      }
      .panels {
        display: grid; grid-template-columns: 1fr 1fr 1fr;
        height: 100%; width: 100%;
      }
      .panel {
        position: relative; overflow: hidden;
        display: flex; flex-direction: column;
      }
      .panels .panel:not(:last-child) {
        border-right: 1px dashed rgba(212,160,23,0.1);
      }

      /* ===== SHARED DECORATIVES ===== */
      .corner-orn {
        position: absolute; width: 28px; height: 28px; pointer-events: none; z-index: 5;
      }
      .corner-orn.tl { top: 6px; left: 6px; }
      .corner-orn.tr { top: 6px; right: 6px; transform: scaleX(-1); }
      .corner-orn.bl { bottom: 6px; left: 6px; transform: scaleY(-1); }
      .corner-orn.br { bottom: 6px; right: 6px; transform: scale(-1,-1); }

      .mandala-bg {
        position: absolute; pointer-events: none; opacity: 0.045;
      }
      .mandala-ring { fill: none; stroke: #d4a017; stroke-width: 0.5; }
      .mandala-ring-thick { fill: none; stroke: #d4a017; stroke-width: 1; }

      .lotus-div { display: block; margin: 0 auto; height: 10px; opacity: 0.55; }
      .gold-line {
        width: 60px; height: 1px;
        background: linear-gradient(to right, transparent, #d4a017, transparent);
        margin: 6px auto;
      }
      .gold-line-w {
        width: 85%; height: 1px;
        background: linear-gradient(to right, transparent, rgba(212,160,23,0.35), rgba(212,160,23,0.6), rgba(212,160,23,0.35), transparent);
        margin: 8px auto;
      }

      /* Dots overlay */
      .dots-ov {
        position: absolute; inset: 0; pointer-events: none;
        background-image: radial-gradient(rgba(212,160,23,0.05) 1px, transparent 1px);
        background-size: 14px 14px;
      }
      /* Concentric rings overlay */
      .rings-ov {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(circle at 50% 50%, transparent 28%, rgba(212,160,23,0.015) 28.5%, transparent 29%),
          radial-gradient(circle at 50% 50%, transparent 42%, rgba(212,160,23,0.012) 42.5%, transparent 43%),
          radial-gradient(circle at 50% 50%, transparent 56%, rgba(212,160,23,0.01) 56.5%, transparent 57%),
          radial-gradient(circle at 50% 50%, transparent 70%, rgba(212,160,23,0.008) 70.5%, transparent 71%);
      }
      /* Diamond lattice */
      .lattice-ov {
        position: absolute; inset: 0; pointer-events: none;
        background:
          linear-gradient(45deg, rgba(212,160,23,0.02) 25%, transparent 25%),
          linear-gradient(-45deg, rgba(212,160,23,0.02) 25%, transparent 25%),
          linear-gradient(45deg, transparent 75%, rgba(212,160,23,0.02) 75%),
          linear-gradient(-45deg, transparent 75%, rgba(212,160,23,0.02) 75%);
        background-size: 20px 20px;
        background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
      }
      /* Border glow strip */
      .border-glow-l {
        position: absolute; top: 0; bottom: 0; right: 0; width: 1px; pointer-events: none;
        background: linear-gradient(180deg, transparent, rgba(212,160,23,0.15), rgba(212,160,23,0.3), rgba(212,160,23,0.15), transparent);
      }
      .border-glow-t {
        position: absolute; top: 0; left: 0; right: 0; height: 1px; pointer-events: none;
        background: linear-gradient(90deg, transparent, rgba(212,160,23,0.2), transparent);
      }

      /* ============================================
         OUTSIDE — PANEL 1: BACK FLAP
         ============================================ */
      .out-flap {
        background: linear-gradient(170deg, #0e0e32 0%, #0d0d2b 100%);
        padding: 0.3in 0.25in;
        justify-content: space-between;
        text-align: center;
      }
      .flap-title {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 12px; font-weight: 700; letter-spacing: 0.18em;
      }
      .activity-card {
        background: none; border: none;
        border-left: 2px solid rgba(212,160,23,0.35);
        padding: 5px 0 5px 10px; margin-bottom: 4px; text-align: left;
      }
      .activity-card .day {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 7px; font-weight: 700; letter-spacing: 0.1em; margin-bottom: 1px;
      }
      .activity-card .desc {
        color: rgba(245,240,232,0.75); font-size: 7px; line-height: 1.4;
      }
      .soon-label {
        font-family: 'Cinzel', serif; color: #f0c040;
        font-size: 9px; font-weight: 600; letter-spacing: 0.12em; margin-bottom: 6px;
      }
      .soon-tags { display: flex; gap: 4px; justify-content: center; flex-wrap: wrap; }
      .soon-tag {
        background: none; border: none; padding: 0;
        font-size: 6.5px; color: #f0c040; letter-spacing: 0.05em;
      }
      .soon-tags .soon-tag:not(:last-child)::after {
        content: '·'; margin-left: 5px; color: rgba(212,160,23,0.4);
      }
      .np-note {
        font-size: 5.5px; color: rgba(245,240,232,0.28); line-height: 1.4; margin-top: 8px;
      }

      /* ============================================
         OUTSIDE — PANEL 2: BACK COVER
         ============================================ */
      .out-back { padding: 0.3in 0.25in; }
      .don-title {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-align: center;
      }
      .don-note {
        font-size: 7px; color: rgba(245,240,232,0.5);
        font-family: 'Playfair Display', Georgia, serif; font-style: italic;
        text-align: center; line-height: 1.5; margin: 6px 0 10px;
      }
      .don-row {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 0; border-bottom: 1px solid rgba(212,160,23,0.07);
      }
      .don-icon {
        width: 16px; height: 16px; border-radius: 50%;
        background: rgba(212,160,23,0.08); border: 1px solid rgba(212,160,23,0.2);
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      }
      .don-icon svg { width: 8px; height: 8px; }
      .don-label {
        font-family: 'Cinzel', serif; font-size: 6.5px;
        color: #d4a017; font-weight: 700; letter-spacing: 0.08em; min-width: 42px;
      }
      .don-val { font-size: 7px; color: rgba(245,240,232,0.8); }
      .contact-title {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 9px; font-weight: 700; letter-spacing: 0.15em;
        text-align: center; margin-bottom: 8px;
      }
      .contact-row {
        font-size: 6.5px; color: rgba(245,240,232,0.6);
        margin-bottom: 3px; text-align: center;
      }
      .contact-row strong { color: rgba(245,240,232,0.85); }

      /* ============================================
         OUTSIDE — PANEL 3: FRONT COVER
         ============================================ */
      .out-front {
        background:
          radial-gradient(ellipse at 50% 35%, rgba(74,32,128,0.12) 0%, transparent 55%),
          linear-gradient(180deg, #080820 0%, #0d0d2b 40%, #0f0f35 100%);
        text-align: center;
      }

      /* Full-bleed venue exterior at top */
      .front-venue-hero {
        position: relative; height: 160px; margin: 0;
        overflow: hidden;
      }
      .front-venue-hero img {
        width: 100%; height: 100%; object-fit: cover;
      }
      .front-venue-hero-ov {
        position: absolute; inset: 0;
        background: linear-gradient(180deg,
          rgba(8,8,32,0.3) 0%,
          rgba(13,13,43,0.5) 50%,
          rgba(13,13,43,0.97) 90%,
          #0d0d2b 100%
        );
      }
      .front-venue-hero .sanskrit-float {
        position: absolute; bottom: 8px; left: 0; right: 0;
        font-size: 5.5px; color: rgba(245,240,232,0.3);
        line-height: 1.7; font-style: italic; text-align: center;
      }

      .front-body {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 0 0.25in 0.2in; position: relative; z-index: 2;
      }

      .front-logo-wrap { position: relative; margin: 0 auto 4px; }
      .front-logo-glow {
        position: absolute; inset: -12px; border-radius: 50%;
        background: radial-gradient(circle, rgba(212,160,23,0.2) 0%, transparent 70%);
      }
      .front-logo {
        width: 88px; height: 88px; border-radius: 50%;
        border: 2.5px solid rgba(212,160,23,0.55); object-fit: cover;
        position: relative; z-index: 1;
        box-shadow: 0 0 35px rgba(212,160,23,0.2);
      }

      .front-title {
        font-family: 'Cinzel', serif; font-size: 26px; font-weight: 800;
        letter-spacing: 0.22em; line-height: 1.12; margin-top: 4px;
        background: linear-gradient(135deg, #d4a017, #f0c040, #b8860b);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      }
      .front-sub {
        font-family: 'Cinzel', serif; color: #f0c040;
        font-size: 13px; letter-spacing: 0.35em; opacity: 0.8;
      }
      .front-tag {
        font-family: 'Playfair Display', Georgia, serif; font-style: italic;
        color: rgba(245,240,232,0.6); font-size: 8px; margin-top: 4px;
      }
      .front-evt {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 10px; font-weight: 700; letter-spacing: 0.22em; margin-top: 2px;
      }
      .front-date {
        font-family: 'Cinzel', serif; color: #f5f0e8;
        font-size: 17px; font-weight: 700; letter-spacing: 0.06em; margin-top: 3px;
      }
      .front-day {
        font-size: 7.5px; color: rgba(245,240,232,0.5); letter-spacing: 0.15em;
      }
      .front-ven {
        margin-top: 6px; font-size: 7px; color: rgba(245,240,232,0.5); line-height: 1.5;
      }
      .front-ven strong {
        color: #d4a017; font-family: 'Cinzel', serif;
        font-size: 7.5px; display: block; letter-spacing: 0.06em;
      }
      .front-inv {
        font-family: 'Playfair Display', Georgia, serif; font-style: italic;
        color: rgba(245,240,232,0.4); font-size: 6.5px; margin-top: 8px; line-height: 1.6;
      }

      /* ============================================
         INSIDE — PANEL 4: CHIEF GUEST
         ============================================ */
      .in-guest {
        background: linear-gradient(180deg, #080820 0%, #0d0d2b 100%);
      }
      .guest-hero {
        position: relative; height: 320px; overflow: hidden;
      }
      .guest-hero img {
        width: 100%; height: 100%; object-fit: cover; object-position: top center;
      }
      .guest-hero-ov {
        position: absolute; inset: 0;
        background: linear-gradient(180deg,
          rgba(8,8,32,0.05) 0%,
          rgba(13,13,43,0.15) 40%,
          rgba(13,13,43,0.7) 75%,
          #0d0d2b 100%
        );
      }
      .guest-badge {
        position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 7px; font-weight: 700; letter-spacing: 0.25em;
        background: rgba(13,13,43,0.6); backdrop-filter: blur(4px);
        padding: 3px 12px; border: 1px solid rgba(212,160,23,0.3); border-radius: 2px; z-index: 3;
      }
      .guest-name-float {
        position: absolute; bottom: 12px; left: 0; right: 0; text-align: center; z-index: 3;
      }
      .guest-name-float h3 {
        font-family: 'Cinzel', serif; color: #f5f0e8;
        font-size: 15px; font-weight: 700; letter-spacing: 0.08em;
        text-shadow: 0 2px 12px rgba(0,0,0,0.6);
      }
      .guest-name-float .sub {
        font-family: 'Playfair Display', Georgia, serif; font-style: italic;
        font-size: 7px; color: rgba(245,240,232,0.5); margin-top: 2px;
      }

      .guest-content { padding: 6px 0.25in 0.2in; position: relative; z-index: 2; }
      .guest-bio {
        font-size: 6.5px; color: rgba(245,240,232,0.72);
        line-height: 1.6; text-align: justify;
      }
      .guest-works {
        display: flex; gap: 10px; justify-content: center;
        align-items: flex-end; margin-top: 8px; flex: 1;
      }
      .gw-item { text-align: center; flex: 1; display: flex; flex-direction: column; align-items: center; }
      .gw-img {
        border-radius: 4px; border: 1.5px solid rgba(212,160,23,0.3);
        object-fit: cover; box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        width: 100%; max-width: 120px;
      }
      .gw-cap {
        font-size: 5.5px; color: rgba(245,240,232,0.4);
        margin-top: 3px; font-style: italic;
      }

      /* ============================================
         INSIDE — PANEL 5: PROGRAM
         ============================================ */
      .in-prog { padding: 0; display: flex; flex-direction: column; }

      .prog-top { padding: 0.25in 0.25in 0; flex: 1; position: relative; z-index: 2; }
      .prog-title {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 15px; font-weight: 700; letter-spacing: 0.2em; text-align: center;
      }
      .prog-items { margin-top: 8px; }
      .prog-row {
        display: flex; align-items: center; padding: 5px 6px; border-radius: 2px;
      }
      .prog-row:nth-child(odd) { background: rgba(26,26,78,0.25); }
      .prog-row .time {
        font-family: 'Cinzel', serif; font-size: 6.5px;
        color: #d4a017; font-weight: 700; min-width: 50px; letter-spacing: 0.03em;
      }
      .prog-row .dot {
        width: 4px; height: 4px; border-radius: 50%;
        background: rgba(212,160,23,0.25); margin: 0 6px; flex-shrink: 0;
      }
      .prog-row .evt {
        font-size: 8px; color: rgba(245,240,232,0.85);
      }
      .prog-row.hl .evt { color: #f0c040; font-weight: 600; }
      .prog-row.hl .dot { background: #d4a017; box-shadow: 0 0 6px rgba(212,160,23,0.4); }

      /* Full-bleed venue at bottom */
      .venue-full {
        position: relative; height: 180px; margin-top: auto;
      }
      .venue-full-grid {
        height: 100%;
      }
      .venue-full-grid img { width: 100%; height: 100%; object-fit: cover; }
      .venue-full-ov {
        position: absolute; inset: 0;
        background: linear-gradient(0deg,
          rgba(13,13,43,0.9) 0%,
          rgba(13,13,43,0.45) 40%,
          rgba(13,13,43,0.15) 100%
        );
        display: flex; flex-direction: column; justify-content: flex-end;
        padding: 0 14px 12px; text-align: center;
      }
      .ven-label {
        font-family: 'Cinzel', serif; font-size: 8px;
        color: #d4a017; letter-spacing: 0.15em; font-weight: 700;
      }
      .ven-name {
        font-family: 'Cinzel', serif; font-size: 7px;
        color: rgba(245,240,232,0.8); letter-spacing: 0.06em; margin-top: 2px;
      }
      .ven-addr { font-size: 6px; color: rgba(245,240,232,0.5); margin-top: 1px; }

      /* ============================================
         INSIDE — PANEL 6: CHAAYAMUKHI
         ============================================ */
      .in-chaaya {
        background: linear-gradient(180deg, #080820 0%, #0d0d2b 100%);
      }
      .chaaya-hero {
        position: relative; height: 300px; overflow: hidden;
      }
      .chaaya-hero img {
        width: 100%; height: 100%; object-fit: cover; object-position: top center;
      }
      .chaaya-hero-ov {
        position: absolute; inset: 0;
        background: linear-gradient(180deg,
          rgba(8,8,32,0.05) 0%,
          rgba(13,13,43,0.15) 40%,
          rgba(13,13,43,0.7) 75%,
          #0d0d2b 100%
        );
      }
      .chaaya-text-float {
        position: absolute; bottom: 8px; left: 0; right: 0; text-align: center; z-index: 3;
      }
      .chaaya-pre {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 7px; letter-spacing: 0.28em; font-weight: 600;
      }
      .chaaya-t {
        font-family: 'Playfair Display', Georgia, serif; color: #f5f0e8;
        font-size: 26px; font-weight: 700; font-style: italic;
        letter-spacing: 0.04em; text-shadow: 0 3px 20px rgba(0,0,0,0.6);
      }
      .chaaya-st {
        font-family: 'Playfair Display', Georgia, serif; font-style: italic;
        color: rgba(245,240,232,0.5); font-size: 8px;
      }

      .chaaya-content { padding: 6px 0.25in 0.2in; position: relative; z-index: 2; flex: 1; display: flex; flex-direction: column; }
      .chaaya-desc {
        font-size: 7px; color: rgba(245,240,232,0.65);
        line-height: 1.55; text-align: center; padding: 0 2px;
      }

      .sl-sec {
        display: flex; align-items: center; gap: 8px;
        background: none; border: none;
        padding: 6px 0; margin-top: 8px;
      }
      .sl-img {
        width: 38px; height: 38px; border-radius: 50%;
        object-fit: cover; border: 1px solid rgba(212,160,23,0.25); flex-shrink: 0;
      }
      .sl-text { text-align: left; }
      .sl-text .n {
        font-family: 'Playfair Display', Georgia, serif;
        color: #d4a017; font-size: 8px; font-weight: 600;
      }
      .sl-text .tl {
        font-size: 5.5px; color: rgba(245,240,232,0.4); font-style: italic;
      }
      .sl-text .d {
        font-size: 6px; color: rgba(245,240,232,0.5); line-height: 1.4; margin-top: 1px;
      }

      .rsvp-box {
        background: none; border: none;
        padding: 8px 0; margin-top: auto; text-align: center;
        position: relative;
      }
      .rsvp-box .rt {
        font-family: 'Cinzel', serif; color: #d4a017;
        font-size: 9px; font-weight: 700; letter-spacing: 0.18em;
        margin-bottom: 3px; position: relative;
      }
      .rsvp-box .rd {
        font-size: 6px; color: rgba(245,240,232,0.55); line-height: 1.5;
        font-family: 'Playfair Display', Georgia, serif; font-style: italic;
        position: relative;
      }

      /* ===== PRINT ===== */
      @media print {
        .screen-controls, .screen-label, .back-to-site { display: none !important; }
        body { background: white; margin: 0; padding: 0; }
        .flyer-page {
          margin: 0; box-shadow: none; page-break-after: always;
          -webkit-print-color-adjust: exact; print-color-adjust: exact;
        }
        @page { size: 11in 8.5in landscape; margin: 0; }
      }
    </style>
  </head>
  <body>
    <div class="screen-controls">
      <h1>TRI-FOLD FLYER PREVIEW</h1>
      <div class="btn-group">
        <button id="btn-both" class="active" onclick="showView('both')">Both Sides</button>
        <button id="btn-outside" onclick="showView('outside')">Outside</button>
        <button id="btn-inside" onclick="showView('inside')">Inside</button>
        <button onclick="window.print()">Print / Save PDF</button>
        <a href={`${base}/`} class="ctrl-link">Back to Site</a>
      </div>
    </div>

    <!-- SVG defs -->
    <svg style="position:absolute;width:0;height:0;" aria-hidden="true">
      <defs>
        <symbol id="co" viewBox="0 0 28 28">
          <path d="M2 26 L2 7 Q2 2 7 2 L26 2" fill="none" stroke="#d4a017" stroke-width="0.7" opacity="0.3"/>
          <path d="M2 20 L2 11 Q2 5 7 5" fill="none" stroke="#d4a017" stroke-width="0.4" opacity="0.18"/>
