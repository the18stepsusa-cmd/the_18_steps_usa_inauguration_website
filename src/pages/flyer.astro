    <script>
      function showView(view) {
        const outside = document.getElementById('page-outside');
        const inside = document.getElementById('page-inside');
        const labels = document.querySelectorAll('.screen-label');
        const buttons = document.querySelectorAll('.screen-controls .btn-group button');
        buttons.forEach(b => b.classList.remove('active'));
        if (view === 'outside') {
          outside.style.display = 'block'; inside.style.display = 'none';
          labels[0].style.display = 'block'; labels[1].style.display = 'none';
          document.getElementById('btn-outside').classList.add('active');
        } else if (view === 'inside') {
          outside.style.display = 'none'; inside.style.display = 'block';
          labels[0].style.display = 'none'; labels[1].style.display = 'block';
          document.getElementById('btn-inside').classList.add('active');
        } else {
          outside.style.display = 'block'; inside.style.display = 'block';
          labels[0].style.display = 'block'; labels[1].style.display = 'block';
          document.getElementById('btn-both').classList.add('active');
        }
      }
    </script>
